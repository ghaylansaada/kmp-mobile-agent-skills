package com.example.app.data.repository

import com.example.app.data.local.AppDatabase
import com.example.app.data.local.entity.{{ENTITY_NAME}}
import com.example.app.data.remote.service.{{SERVICE_NAME}}
import com.example.app.data.remote.util.ApiCall
import com.example.app.data.remote.util.ApiResult
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.onStart

class {{FEATURE_NAME}}RepositoryImpl(
    private val {{feature_name}}Service: {{SERVICE_NAME}},
    private val database: AppDatabase,
) : {{FEATURE_NAME}}Repository {

    override fun observe{{FEATURE_NAME}}(): Flow<{{ENTITY_NAME}}?> =
        database.{{feature_name}}Dao.select{{FEATURE_NAME}}()
            .onStart { callApi() }

    override suspend fun callApi(): ApiResult<List<{{ENTITY_NAME}}>> {
        return object : ApiCall<List<{{ENTITY_NAME}}>>() {
            override suspend fun webserviceCall() =
                {{feature_name}}Service.get{{FEATURE_NAME}}s()
            override suspend fun onSuccess(data: List<{{ENTITY_NAME}}>) {
                database.{{feature_name}}Dao.insertAll(data)
            }
            override suspend fun onFailure(statusCode: Int, message: String?) { }
        }.execute()
    }
}

