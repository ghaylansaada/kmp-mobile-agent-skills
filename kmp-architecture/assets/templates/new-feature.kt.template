package com.example.app.presentation.{{feature_name}}

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import com.example.app.data.repository.{{FEATURE_NAME}}Repository
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.flow.update
import kotlinx.coroutines.launch

class {{FEATURE_NAME}}ViewModel(
    private val {{feature_name}}Repository: {{FEATURE_NAME}}Repository,
) : ViewModel() {

    private val _uiState =
        MutableStateFlow<{{FEATURE_NAME}}UiState>({{FEATURE_NAME}}UiState.Loading)
    val uiState: StateFlow<{{FEATURE_NAME}}UiState> = _uiState.asStateFlow()

    init {
        viewModelScope.launch {
            {{feature_name}}Repository.observe{{FEATURE_NAME}}().collect { entity ->
                _uiState.update {
                    {{FEATURE_NAME}}UiState.Success({{feature_name}} = entity)
                }
            }
        }
    }

    fun onEvent(event: {{FEATURE_NAME}}UiEvent) {
        when (event) {
            {{FEATURE_NAME}}UiEvent.Refresh -> refresh()
            {{FEATURE_NAME}}UiEvent.Retry -> refresh()
        }
    }

    private fun refresh() {
        viewModelScope.launch {
            _uiState.update {
                when (it) {
                    is {{FEATURE_NAME}}UiState.Success ->
                        it.copy(isRefreshing = true)
                    else -> {{FEATURE_NAME}}UiState.Loading
                }
            }
            val result = {{feature_name}}Repository.callApi()
            if (!result.isSuccess) {
                _uiState.update {
                    {{FEATURE_NAME}}UiState.Error(
                        statusCode = result.statusCode ?: 0,
                        message = result.message,
                    )
                }
            }
        }
    }
}

