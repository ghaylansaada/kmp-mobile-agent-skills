// -- State --

@Immutable
data class {{ScreenName}}UiState(
    val items: List<String> = emptyList(),
    val isLoading: Boolean = false,
    val errorMessage: String? = null,
)

// -- Stateful Screen --
// Do NOT add @Preview here; koinInject() crashes without Koin initialization.

@Composable
fun {{ScreenName}}Screen(
    modifier: Modifier = Modifier,
    viewModel: {{ScreenName}}ViewModel = koinInject(),
) {
    val uiState by viewModel.uiState.collectAsState()

    {{ScreenName}}ScreenContent(
        modifier = modifier,
        uiState = uiState,
        onRefresh = { viewModel.refresh() },
    )
}

// -- Stateless Content (safe for @Preview) --

@Composable
fun {{ScreenName}}ScreenContent(
    modifier: Modifier = Modifier,
    uiState: {{ScreenName}}UiState,
    onRefresh: () -> Unit,
) {
    Column(
        modifier = modifier
            .fillMaxSize()
            .padding(AppTheme.spacing.lg),
    ) {
        Text(
            text = stringResource(Res.string.screen_title), // Res.string.screen_title
            style = MaterialTheme.typography.titleLarge,
        )

        Spacer(Modifier.height(AppTheme.spacing.lg))

        // -- Animated loading indicator --
        AnimatedVisibility(
            visible = uiState.isLoading,
            enter = fadeIn(tween(AppTheme.motion.durationMedium)) + slideInVertically(initialOffsetY = { -it / 2 }),
            exit = fadeOut(tween(AppTheme.motion.durationShort)) + slideOutVertically(targetOffsetY = { -it / 2 }),
        ) {
            Row(
                verticalAlignment = Alignment.CenterVertically,
                modifier = Modifier.padding(bottom = AppTheme.spacing.lg),
            ) {
                CircularProgressIndicator(
                    modifier = Modifier
                        .size(AppTheme.sizing.iconMd)
                        .semantics { contentDescription = stringResource(Res.string.cd_loading) },
                    strokeWidth = AppTheme.sizing.strokeMedium,
                )
                Spacer(Modifier.width(AppTheme.spacing.sm))
                Text(
                    text = stringResource(Res.string.label_loading), // Res.string.label_loading
                    style = MaterialTheme.typography.bodySmall,
                )
            }
        }

        // -- Animated error banner --
        AnimatedVisibility(
            visible = uiState.errorMessage != null,
            enter = fadeIn(tween(AppTheme.motion.durationMedium)) + slideInVertically(),
            exit = fadeOut(tween(AppTheme.motion.durationShort)) + slideOutVertically(),
        ) {
            val errorColor by animateColorAsState(
                targetValue = MaterialTheme.colorScheme.errorContainer,
                animationSpec = tween(AppTheme.motion.durationMedium),
                label = "errorBgColor",
            )
            Card(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(bottom = AppTheme.spacing.lg),
                colors = androidx.compose.material3.CardDefaults.cardColors(
                    containerColor = errorColor,
                ),
            ) {
                Text(
                    text = uiState.errorMessage.orEmpty(),
                    modifier = Modifier.padding(AppTheme.spacing.lg),
                    color = MaterialTheme.colorScheme.onErrorContainer,
                )
            }
        }

        // -- Expandable content card with animateContentSize --
        var isExpanded by remember { mutableStateOf(false) }

        Card(
            modifier = Modifier
                .fillMaxWidth()
                .animateContentSize(
                    animationSpec = spring(
                        dampingRatio = Spring.DampingRatioLowBouncy,
                        stiffness = Spring.StiffnessMediumLow,
                    ),
                ),
            onClick = { isExpanded = !isExpanded },
        ) {
            Column(modifier = Modifier.padding(AppTheme.spacing.lg)) {
                Row(verticalAlignment = Alignment.CenterVertically) {
                    Text(
                        text = stringResource(Res.string.label_details), // Res.string.label_details
                        style = MaterialTheme.typography.titleMedium,
                        modifier = Modifier.weight(1f),
                    )
                    Icon(
                        imageVector = if (isExpanded) Icons.Default.ExpandLess
                                      else Icons.Default.ExpandMore,
                        contentDescription = if (isExpanded) stringResource(Res.string.cd_collapse)
                                             else stringResource(Res.string.cd_expand),
                    )
                }
                if (isExpanded) {
                    Spacer(Modifier.height(AppTheme.spacing.sm))
                    Text(
                        text = stringResource(Res.string.label_expanded_content), // Res.string.label_expanded_content
                        style = MaterialTheme.typography.bodyMedium,
                    )
                }
            }
        }

        Spacer(Modifier.height(AppTheme.spacing.lg))

        // -- Animated item count with AnimatedContent --
        AnimatedContent(
            targetState = uiState.items.size,
            transitionSpec = {
                if (targetState > initialState) {
                    slideInVertically(initialOffsetY = { it }) + fadeIn() togetherWith
                        slideOutVertically(targetOffsetY = { -it }) + fadeOut()
                } else {
                    slideInVertically(initialOffsetY = { -it }) + fadeIn() togetherWith
                        slideOutVertically(targetOffsetY = { it }) + fadeOut()
                }
            },
            label = "itemCount",
        ) { count ->
            Text(
                text = stringResource(Res.string.label_item_count, count), // Res.string.label_item_count
                style = MaterialTheme.typography.bodyLarge,
            )
        }

        Spacer(Modifier.weight(1f))

        Button(
            onClick = onRefresh,
            enabled = !uiState.isLoading,
            modifier = Modifier.fillMaxWidth(),
        ) {
            Text(stringResource(Res.string.action_refresh)) // Res.string.action_refresh
        }
    }
}

