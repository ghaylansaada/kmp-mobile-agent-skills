interface {{EntityName}}Service {

    @GET("{{entityPath}}")
    suspend fun getAll(
        @Query("page") page: Int,
        @Query("limit") limit: Int,
    ): ApiResult<List<{{EntityDto}}>>

    @GET("{{entityPath}}/{id}")
    suspend fun getById(
        @Path("id") id: String,
    ): ApiResult<{{EntityDto}}>

    @POST("{{entityPath}}")
    suspend fun create(
        @Body body: {{CreateRequestDto}},
    ): ApiResult<{{EntityDto}}>

    @PUT("{{entityPath}}/{id}")
    suspend fun update(
        @Path("id") id: String,
        @Body body: {{UpdateRequestDto}},
    ): ApiResult<{{EntityDto}}>

    @DELETE("{{entityPath}}/{id}")
    suspend fun delete(
        @Path("id") id: String,
    ): ApiResult<Unit>
}
