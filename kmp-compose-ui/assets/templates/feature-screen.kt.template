import {your.package}.ui.components.inputs.errorsForField
import {your.package}.ui.components.states.ErrorStateFromThrowable
import {your.package}.ui.components.states.FullScreenLoading
import {your.package}.ui.theme.AppTheme
import org.koin.compose.koinInject

// --- UI State ---

@Immutable
data class {{FeatureName}}UiState(
    val isLoading: Boolean = false,
    val error: Throwable? = null,
    val fieldErrors: List<ApiError> = emptyList(),
    val isSubmitting: Boolean = false,
    val name: String = "",
    val email: String = "",
)

// --- Screen Composable ---

@Composable
fun {{FeatureName}}Screen(
    onNavigateBack: () -> Unit,
    modifier: Modifier = Modifier,
    // viewModel: {{FeatureName}}ViewModel = koinInject(),
) {
    // val uiState by viewModel.uiState.collectAsState()
    var uiState by remember { mutableStateOf({{FeatureName}}UiState()) }

    val snackbarHostState = remember { SnackbarHostState() }
    var showConfirmDialog by remember { mutableStateOf(false) }

    ErrorSnackbarEffect(
        error = uiState.error,
        hostState = snackbarHostState,
        actionLabel = stringResource(Res.string.action_retry),
        onAction = { /* viewModel.retry() */ },
    )

    Scaffold(
        snackbarHost = { AppSnackbarHost(hostState = snackbarHostState) },
    ) { padding ->
        when {
            uiState.isLoading -> {
                FullScreenLoading(
                    message = stringResource(Res.string.loading),
                    modifier = modifier,
                )
            }
            uiState.error != null && !uiState.isSubmitting -> {
                ErrorStateFromThrowable(
                    error = uiState.error!!,
                    onRetry = { /* viewModel.reload() */ },
                    modifier = modifier,
                )
            }
            else -> {
                Column(
                    modifier = modifier
                        .fillMaxSize()
                        .padding(padding)
                        .padding(AppTheme.spacing.lg),
                ) {
                    AppTextField(
                        value = uiState.name,
                        onValueChange = { uiState = uiState.copy(name = it) },
                        label = stringResource(Res.string.{{featureName}}_label_name),
                        fieldErrors = uiState.fieldErrors.errorsForField("name"),
                        imeAction = ImeAction.Next,
                        accessibilityLabel = stringResource(Res.string.{{featureName}}_label_name),
                    )
                    Spacer(Modifier.height(AppTheme.spacing.md))
                    AppTextField(
                        value = uiState.email,
                        onValueChange = { uiState = uiState.copy(email = it) },
                        label = stringResource(Res.string.{{featureName}}_label_email),
                        fieldErrors = uiState.fieldErrors.errorsForField("email"),
                        keyboardType = KeyboardType.Email,
                        imeAction = ImeAction.Done,
                        onImeAction = { /* viewModel.submit() */ },
                        accessibilityLabel = stringResource(Res.string.{{featureName}}_label_email),
                    )
                    Spacer(Modifier.height(AppTheme.spacing.xl))
                    AppPrimaryButton(
                        text = stringResource(Res.string.action_submit),
                        onClick = { /* viewModel.submit() */ },
                        isLoading = uiState.isSubmitting,
                        accessibilityLabel = stringResource(Res.string.action_submit),
                    )
                    Spacer(Modifier.height(AppTheme.spacing.md))
                    AppOutlinedButton(
                        text = stringResource(Res.string.action_delete),
                        onClick = { showConfirmDialog = true },
                        accessibilityLabel = stringResource(Res.string.action_delete),
                    )
                    Spacer(Modifier.height(AppTheme.spacing.sm))
                    AppTextButton(
                        text = stringResource(Res.string.action_cancel),
                        onClick = onNavigateBack,
                        accessibilityLabel = stringResource(Res.string.action_cancel),
                    )
                }
            }
        }
    }

    if (showConfirmDialog) {
        AppConfirmDialog(
            title = stringResource(Res.string.{{featureName}}_delete_title),
            message = stringResource(Res.string.confirm_delete_message),
            confirmText = stringResource(Res.string.action_delete),
            isDestructive = true,
            onConfirm = {
                showConfirmDialog = false
                // viewModel.delete()
            },
            onDismiss = { showConfirmDialog = false },
        )
    }
}
