package {your.package}.data.pagination

import androidx.paging.PagingState
import {your.package}.core.network.result.ApiResult
import {your.package}.core.paging.BaseRemoteMediator
import {your.package}.data.local.AppDatabase
import {your.package}.data.local.entity.{{ENTITY_NAME}}Entity
import {your.package}.data.remote.service.{{SERVICE_NAME}}

class {{ENTITY_NAME}}RemoteMediator(
    private val service: {{SERVICE_NAME}},
    private val database: AppDatabase,
) : BaseRemoteMediator<{{ENTITY_NAME}}Entity>(database, "{{TYPE_STRING}}") {

    override suspend fun networkResponse(
        page: Int,
        state: PagingState<Int, {{ENTITY_NAME}}Entity>,
    ): ApiResult<List<{{ENTITY_NAME}}Entity>> {
        return service.{{API_METHOD}}(page = page, limit = state.config.pageSize)
    }

    override suspend fun clearCachedDataAfterRefresh() {
        database.{{DAO_PROPERTY}}.clear()
    }

    override suspend fun saveResult(newData: List<{{ENTITY_NAME}}Entity>) {
        database.{{DAO_PROPERTY}}.upsertAll(newData)
    }
}

