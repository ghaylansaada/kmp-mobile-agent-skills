# ===========================================================================
# Keystore configuration for release signing
# Copy this file to composeApp/keystore/keystore.properties and fill in values.
# NEVER commit the filled-in file to version control.
#
# The signing config in build.gradle.kts reads this file for local builds.
# On CI, the signing config falls back to environment variables instead.
# ===========================================================================

storeFile=keystore/release.keystore
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=release
keyPassword=REPLACE_WITH_KEY_PASSWORD
