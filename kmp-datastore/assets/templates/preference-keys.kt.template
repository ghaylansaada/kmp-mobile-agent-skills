// Type-Safe Preference Keys Template
//
// Usage: Copy and replace placeholders marked with {{...}}.
// Each preference key group should be a sealed interface with a companion
// object holding the keys. This prevents key name collisions and provides
// IDE-navigable references.

package {your.package}.core.datastore

import androidx.datastore.preferences.core.Preferences
import androidx.datastore.preferences.core.booleanPreferencesKey
import androidx.datastore.preferences.core.doublePreferencesKey
import androidx.datastore.preferences.core.floatPreferencesKey
import androidx.datastore.preferences.core.intPreferencesKey
import androidx.datastore.preferences.core.longPreferencesKey
import androidx.datastore.preferences.core.stringPreferencesKey
import androidx.datastore.preferences.core.stringSetPreferencesKey

// Session Keys -- tokens and user identification
sealed interface SessionKeys {
    companion object {
        val ACCESS_TOKEN: Preferences.Key<String> =
            stringPreferencesKey("session.accessToken")
        val REFRESH_TOKEN: Preferences.Key<String> =
            stringPreferencesKey("session.refreshToken")
        val USER_ID: Preferences.Key<String> =
            stringPreferencesKey("session.userId")
    }
}

