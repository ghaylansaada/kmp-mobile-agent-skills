// Example: App Preferences
sealed interface AppKeys {
    companion object {
        val ONBOARDING_COMPLETE: Preferences.Key<Boolean> =
            booleanPreferencesKey("app.onboardingComplete")
        val THEME_MODE: Preferences.Key<String> =
            stringPreferencesKey("app.themeMode")
        val LANGUAGE: Preferences.Key<String> =
            stringPreferencesKey("app.language")
        val NOTIFICATION_COUNT: Preferences.Key<Int> =
            intPreferencesKey("app.notificationCount")
        val LAST_SYNC_TIMESTAMP: Preferences.Key<Long> =
            longPreferencesKey("app.lastSyncTimestamp")
        val FAVORITE_IDS: Preferences.Key<Set<String>> =
            stringSetPreferencesKey("app.favoriteIds")
    }
}
